# Copy this file to .env at the repository root and fill in only the values you use.
# Do not commit real secrets.

# OpenAI-compatible auth
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=
OPENAI_GRADIENT_MODEL=
OPENAI_APPLY_EDIT_MODEL=

# GitHub Models auth
# Leave these blank unless you explicitly want to use GitHub Models.
GITHUB_MODELS_API_KEY=
GITHUB_MODELS_ENDPOINT=
GITHUB_MODELS_MODEL=
GITHUB_MODELS_GRADIENT_MODEL=
GITHUB_MODELS_APPLY_EDIT_MODEL=

# Copilot-backed SDK inference (no model-provider API keys)
# Set INFERENCE_PROVIDER=github_copilot to opt into the SDK-backed signed-in Copilot adapter.
INFERENCE_PROVIDER=
COPILOT_MODEL=default
