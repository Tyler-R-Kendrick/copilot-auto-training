# Copy this file to .env at the repository root and fill in only the values you use.
# Do not commit real secrets.

# OpenAI-compatible auth
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=

# GitHub Models auth
GITHUB_MODELS_API_KEY=
GITHUB_MODELS_ENDPOINT=https://models.github.ai/inference
GITHUB_MODELS_MODEL=openai/gpt-4.1-mini
GITHUB_MODELS_GRADIENT_MODEL=openai/gpt-4.1-mini
GITHUB_MODELS_APPLY_EDIT_MODEL=openai/gpt-4.1-mini